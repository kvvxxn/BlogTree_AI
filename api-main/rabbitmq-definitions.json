{
  "rabbit_version": "3.12",
  "users": [
    { "name": "rabbitmq_user", "password": "rabbitmq_password", "tags": "administrator" }
  ],
  "vhosts": [ { "name": "/" } ],
  "permissions": [
    { "user": "rabbitmq_user", "vhost": "/", "configure": ".*", "write": ".*", "read": ".*" }
  ],
  "exchanges": [
    { "name": "summary.exchange", "vhost": "/", "type": "topic", "durable": true },
    { "name": "dlx.exchange", "vhost": "/", "type": "direct", "durable": true }
  ],
  "queues": [
    { "name": "summary.request.queue", "vhost": "/", "durable": true },

    {
      "name": "summary.response.queue",
      "vhost": "/",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "dlx.exchange",
        "x-dead-letter-routing-key": "summary.response.dead"
      }
    },

    { "name": "summary.response.dlq", "vhost": "/", "durable": true }
  ],
  "bindings": [
    {
      "source": "summary.exchange", "vhost": "/", "destination": "summary.request.queue",
      "destination_type": "queue", "routing_key": "summary.request"
    },
    {
      "source": "summary.exchange", "vhost": "/", "destination": "summary.response.queue",
      "destination_type": "queue", "routing_key": "summary.response"
    },
    {
      "source": "dlx.exchange", "vhost": "/", "destination": "summary.response.dlq",
      "destination_type": "queue", "routing_key": "summary.response.dead"
    }
  ]
}
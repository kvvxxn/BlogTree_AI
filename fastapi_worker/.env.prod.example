# Required
APP_ENV=prod
LLM_API_KEY=your-openai-api-key

# Required in prod: choose one style.
# 1) Full URL
# RABBITMQ_URL=amqps://user:password@b-xxxx.mq.ap-northeast-2.amazonaws.com:5671/%2F

# 2) Granular fields
RABBITMQ_HOST=b-xxxx.mq.ap-northeast-2.amazonaws.com
RABBITMQ_PORT=5671
RABBITMQ_USER=blogtree_worker
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/
RABBITMQ_SSL=true

# Optional integrations
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
# LANGFUSE_BASE_URL=

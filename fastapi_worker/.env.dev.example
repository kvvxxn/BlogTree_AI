# Required
LLM_API_KEY=your-openai-api-key

# Optional in dev
# APP_ENV=dev
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=rabbitmq_user
# RABBITMQ_PASSWORD=rabbitmq_password
# RABBITMQ_VHOST=/
# RABBITMQ_SSL=false

# Optional integrations
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
# LANGFUSE_BASE_URL=
